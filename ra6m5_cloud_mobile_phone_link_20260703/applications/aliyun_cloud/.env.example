# Flask listen host. Use 0.0.0.0 so the RA board can access this service in LAN.
APP_HOST=0.0.0.0

# Flask listen port.
APP_PORT=5000

# Public or LAN base URL used to generate report/qrcode links.
# Local PC browser:
# BASE_URL=http://127.0.0.1:5000
#
# RA board in the same WiFi:
# BASE_URL=http://192.168.x.x:5000
#
# Cloud server:
# BASE_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN:5000
BASE_URL=http://127.0.0.1:5000
